# Database (PostgreSQL — Supabase recommended)
# Transaction pooler URL (used at runtime, supports connection pooling)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection URL (used for migrations/schema push)
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# AI Services
# Get your keys from https://ai.google.dev/
GOOGLE_GENERATIVE_AI_API_KEY="your_api_key_here"

# Auth
# Use a strong random string for JWT_SECRET in production
JWT_SECRET="your_jwt_secret_here"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3003"

# Midtrans Payment Gateway
# Get your keys from https://dashboard.midtrans.com/
MIDTRANS_SERVER_KEY="your_midtrans_server_key_here"
MIDTRANS_CLIENT_KEY="your_midtrans_client_key_here"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your_midtrans_public_client_key_here"
MIDTRANS_IS_PRODUCTION="false"
