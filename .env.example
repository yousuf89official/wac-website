# Database
# Use MySQL or PostgreSQL for Production/Staging on Hostinger
# Example: mysql://user:password@localhost:3306/db_name
DATABASE_URL="file:./dev.db"

# AI Services
# Get your keys from https://ai.google.dev/
GOOGLE_GENERATIVE_AI_API_KEY="your_api_key_here"

# Auth
# Use a strong random string for JWT_SECRET in production
JWT_SECRET="your_jwt_secret_here"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3003"

# Midtrans Payment Gateway
# Get your keys from https://dashboard.midtrans.com/
MIDTRANS_SERVER_KEY="your_midtrans_server_key_here"
MIDTRANS_CLIENT_KEY="your_midtrans_client_key_here"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your_midtrans_public_client_key_here"
MIDTRANS_IS_PRODUCTION="false"
