# Database
# Use MySQL or PostgreSQL for Production/Staging on Hostinger
# Example: mysql://user:password@localhost:3306/db_name
DATABASE_URL="file:./dev.db"

# AI Services
# Get your keys from https://ai.google.dev/
GOOGLE_GENERATIVE_AI_API_KEY="your_api_key_here"

# Auth
# Use a strong random string for NEXTAUTH_SECRET in production
NEXTAUTH_SECRET="your_secret_here"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
